<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.budgetinsight.ExpensesController"
            stylesheets="@styles.css"
            prefWidth="1200.0" prefHeight="750.0">

    <left>
        <VBox prefWidth="220.0" styleClass="sidebar">
            <VBox styleClass="sidebar-header" spacing="2.0">
                <Label text="Budget" styleClass="app-name"/>
                <Label text="Insight" styleClass="app-name-accent"/>
            </VBox>
            <Region prefHeight="1.0" maxWidth="Infinity" styleClass="divider"/>
            <VBox styleClass="sidebar-nav" spacing="4.0">
                <Label text="NAVIGATION" styleClass="nav-label"/>
                <Button text="Dashboard" maxWidth="Infinity" styleClass="nav-btn"        onAction="#onNavDashboard"/>
                <Button text="Expenses"  maxWidth="Infinity" styleClass="nav-btn-active" onAction="#onNavExpenses"/>
                <Button text="Reports"   maxWidth="Infinity" styleClass="nav-btn"        onAction="#onNavReports"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area">

            <HBox alignment="CENTER_LEFT" prefHeight="64.0" styleClass="topbar">
                <Label text="Expenses" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="IC" styleClass="profile-btn"/>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" styleClass="content-padding" spacing="16.0">

                <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="filter-row">
                    <Label text="Min:" styleClass="text-muted"/>
                    <TextField fx:id="minAmountField" promptText="0.00" prefWidth="90.0" styleClass="input-field"/>
                    <Label text="De la:" styleClass="text-muted"/>
                    <DatePicker fx:id="fromDatePicker" prefWidth="145.0"/>
                    <Label text="Pana la:" styleClass="text-muted"/>
                    <DatePicker fx:id="toDatePicker" prefWidth="145.0"/>
                    <Label text="Categorie:" styleClass="text-muted"/>
                    <ComboBox fx:id="categoryFilter" prefWidth="155.0" promptText="Toate categoriile"/>
                    <Button text="Aplica" styleClass="btn-primary" onAction="#onApplyFilter"/>
                    <Button text="Sterge" styleClass="btn-outline" onAction="#onClearFilter"/>
                </HBox>

                <HBox spacing="16.0" VBox.vgrow="ALWAYS">

                    <VBox prefWidth="370.0" styleClass="card">
                        <Label text="Cheltuieli pe categorii" styleClass="section-title"/>
                        <PieChart fx:id="categoryChart" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                        <HBox spacing="8.0" alignment="CENTER_RIGHT">
                            <Button text="+ Adauga"  styleClass="btn-primary"   onAction="#onAddExpense"/>
                            <Button text="Editeaza"  styleClass="btn-secondary" onAction="#onEditExpense"/>
                            <Button text="Sterge"    styleClass="btn-danger"    onAction="#onDeleteExpense"/>
                        </HBox>
                        <TableView fx:id="expensesTable" VBox.vgrow="ALWAYS" styleClass="table-card">
                            <columns>
                                <TableColumn fx:id="dateColumn"        text="Data"        prefWidth="110.0"/>
                                <TableColumn fx:id="descriptionColumn" text="Descriere"   prefWidth="220.0"/>
                                <TableColumn fx:id="categoryColumn"    text="Categorie"   prefWidth="130.0"/>
                                <TableColumn fx:id="amountColumn"      text="Suma (Lei)"  prefWidth="130.0"/>
                            </columns>
                            <placeholder>
                                <Label text="Nu exista cheltuieli." styleClass="text-muted"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>