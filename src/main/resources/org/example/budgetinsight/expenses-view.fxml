<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.budgetinsight.ExpensesController"
            stylesheets="@styles.css"
            prefWidth="1200.0" prefHeight="750.0">

    <left>
        <VBox prefWidth="220.0" styleClass="sidebar">
            <VBox styleClass="sidebar-header" spacing="2.0">
                <Label text="Budget" styleClass="app-name"/>
                <Label text="Insight" styleClass="app-name-accent"/>
            </VBox>
            <Region prefHeight="1.0" maxWidth="Infinity" styleClass="divider"/>
            <VBox styleClass="sidebar-nav" spacing="4.0">
                <Label text="NAVIGATION" styleClass="nav-label"/>
                <Button text="Dashboard" maxWidth="Infinity" styleClass="nav-btn"/>
                <Button text="Expenses"  maxWidth="Infinity" styleClass="nav-btn-active"/>
                <Button text="Reports"   maxWidth="Infinity" styleClass="nav-btn"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area">

            <HBox alignment="CENTER_LEFT" prefHeight="64.0" styleClass="topbar">
                <Label text="Expenses" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="IC" styleClass="profile-btn"/>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" styleClass="content-padding" spacing="16.0">

                <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="filter-row">
                    <Label text="Min Amount:" styleClass="text-muted"/>
                    <TextField promptText="0.00" prefWidth="90.0" styleClass="input-field"/>
                    <Label text="From:" styleClass="text-muted"/>
                    <DatePicker prefWidth="150.0"/>
                    <Label text="To:" styleClass="text-muted"/>
                    <DatePicker prefWidth="150.0"/>
                    <Label text="Category:" styleClass="text-muted"/>
                    <ComboBox fx:id="categoryFilter" prefWidth="150.0" promptText="All Categories"/>
                    <Button text="Apply Filter" styleClass="btn-primary"/>
                    <Button text="Clear"        styleClass="btn-outline"/>
                </HBox>

                <HBox spacing="16.0" VBox.vgrow="ALWAYS">

                    <VBox prefWidth="380.0" styleClass="card">
                        <Label text="Expenses by Category" styleClass="section-title"/>
                        <PieChart fx:id="categoryChart" VBox.vgrow="ALWAYS"/>
                    </VBox>

                    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                        <HBox spacing="8.0" alignment="CENTER_RIGHT">
                            <Button text="+ Add Expense" styleClass="btn-primary"/>
                            <Button text="Edit"           styleClass="btn-secondary"/>
                            <Button text="Delete"         styleClass="btn-danger"/>
                        </HBox>
                        <TableView VBox.vgrow="ALWAYS" styleClass="table-card">
                            <columns>
                                <TableColumn text="Date"           prefWidth="110.0"/>
                                <TableColumn text="Description"    prefWidth="220.0"/>
                                <TableColumn text="Category"       prefWidth="130.0"/>
                                <TableColumn text="Amount (Lei)"   prefWidth="130.0"/>
                            </columns>
                            <placeholder>
                                <Label text="No expenses found." styleClass="text-muted"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>