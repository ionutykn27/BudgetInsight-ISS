<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.budgetinsight.ExpensesController"
            stylesheets="@styles.css"
            prefWidth="1200.0" prefHeight="750.0">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="220.0" styleClass="sidebar">
            <VBox styleClass="sidebar-header" spacing="2.0">
                <Label text="Budget" styleClass="app-name"/>
                <Label text="Insight" styleClass="app-name-accent"/>
            </VBox>
            <Region prefHeight="1.0" maxWidth="Infinity" styleClass="divider"/>
            <VBox styleClass="sidebar-nav" spacing="4.0">
                <Label text="NAVIGARE" styleClass="nav-label"/>
                <Button text="⬡  Dashboard" maxWidth="Infinity" styleClass="nav-btn"        onAction="#onNavDashboard"/>
                <Button text="↗  Cheltuieli" maxWidth="Infinity" styleClass="nav-btn-active" onAction="#onNavExpenses"/>
                <Button text="◫  Rapoarte"   maxWidth="Infinity" styleClass="nav-btn"        onAction="#onNavReports"/>
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox styleClass="content-area">

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT" prefHeight="72.0" styleClass="topbar" spacing="10.0">
                <VBox spacing="3.0">
                    <Label text="Cheltuieli" styleClass="topbar-title"/>
                    <Label fx:id="subtitleLabel" text="" styleClass="topbar-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="filterToggleBtn" text="⚙  Filtre" styleClass="btn-outline" onAction="#onToggleFilter"/>
                <Button text="+ Adaugă" styleClass="accent-button" onAction="#onAddExpense"/>
                <Button text="IC" styleClass="profile-btn"/>
            </HBox>

            <!-- CATEGORY PILLS (built in Java) -->
            <FlowPane fx:id="pillsPane" hgap="8.0" vgap="8.0" styleClass="pills-row"/>

            <!-- FILTER ROW — collapsed by default -->
            <HBox fx:id="filterRow" visible="false" managed="false"
                  spacing="10.0" alignment="CENTER_LEFT" styleClass="filter-row">
                <Label text="Min (Lei):" styleClass="text-muted"/>
                <TextField fx:id="minAmountField" promptText="0.00" prefWidth="78.0" styleClass="input-field"/>
                <Label text="Max (Lei):" styleClass="text-muted"/>
                <TextField fx:id="maxAmountField" promptText="0.00" prefWidth="78.0" styleClass="input-field"/>
                <Label text="De la:" styleClass="text-muted"/>
                <DatePicker fx:id="fromDatePicker" prefWidth="138.0"/>
                <Label text="Până la:" styleClass="text-muted"/>
                <DatePicker fx:id="toDatePicker" prefWidth="138.0"/>
                <Button text="Aplică" styleClass="btn-primary" onAction="#onApplyFilter"/>
                <Button text="Șterge" styleClass="btn-outline" onAction="#onClearFilter"/>
            </HBox>

            <!-- MAIN GRID -->
            <HBox spacing="16.0" VBox.vgrow="ALWAYS" styleClass="content-padding">

                <!-- LEFT: CHART CARD -->
                <VBox prefWidth="350.0" styleClass="glass-card" spacing="6.0">
                    <Label text="Pe categorii" styleClass="section-title"/>
                    <Label text="Distribuția cheltuielilor" styleClass="section-subtitle"/>
                    <StackPane fx:id="chartStack" VBox.vgrow="ALWAYS" minHeight="220.0">
                        <PieChart fx:id="categoryChart"
                                  labelsVisible="false"
                                  legendVisible="false"/>
                    </StackPane>
                    <VBox fx:id="chartLegend" spacing="7.0" styleClass="chart-legend-box"/>
                </VBox>

                <!-- RIGHT: TABLE CARD -->
                <VBox HBox.hgrow="ALWAYS" styleClass="glass-card" spacing="0.0">
                    <HBox spacing="8.0" alignment="CENTER_LEFT" styleClass="table-actions">
                        <Label text="Tranzacții" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Editează" styleClass="btn-secondary" onAction="#onEditExpense"/>
                        <Button text="Șterge"   styleClass="btn-danger"    onAction="#onDeleteExpense"/>
                    </HBox>
                    <TableView fx:id="expensesTable" VBox.vgrow="ALWAYS" styleClass="budget-table">
                        <columns>
                            <TableColumn fx:id="dateColumn"        text="DATĂ"       prefWidth="90.0"/>
                            <TableColumn fx:id="descriptionColumn" text="DESCRIERE"  prefWidth="210.0"/>
                            <TableColumn fx:id="categoryColumn"    text="CATEGORIE"  prefWidth="150.0"/>
                            <TableColumn fx:id="amountColumn"      text="SUMA (LEI)" prefWidth="120.0"/>
                        </columns>
                        <placeholder>
                            <Label text="Nu există cheltuieli." styleClass="text-muted"/>
                        </placeholder>
                    </TableView>
                    <HBox styleClass="table-footer" alignment="CENTER_LEFT">
                        <Label fx:id="countLabel" styleClass="text-muted-sm"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="footerTotalLabel" styleClass="footer-total"/>
                    </HBox>
                </VBox>

            </HBox>
        </VBox>
    </center>
</BorderPane>
