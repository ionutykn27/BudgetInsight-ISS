<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.budgetinsight.ProfileController"
            stylesheets="@styles.css"
            prefWidth="1200.0" prefHeight="750.0">

    <left>
        <VBox prefWidth="220.0" styleClass="sidebar">
            <VBox styleClass="sidebar-header" spacing="2.0">
                <Label text="Budget" styleClass="app-name"/>
                <Label text="Insight" styleClass="app-name-accent"/>
            </VBox>
            <Region prefHeight="1.0" maxWidth="Infinity" styleClass="divider"/>
            <VBox styleClass="sidebar-nav" spacing="4.0">
                <Label text="NAVIGATION" styleClass="nav-label"/>
                <Button text="Dashboard" maxWidth="Infinity" styleClass="nav-btn"/>
                <Button text="Expenses"  maxWidth="Infinity" styleClass="nav-btn"/>
                <Button text="Reports"   maxWidth="Infinity" styleClass="nav-btn"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area">

            <HBox alignment="CENTER_LEFT" prefHeight="64.0" styleClass="topbar">
                <Label text="Profile" styleClass="topbar-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="IC" styleClass="profile-btn"/>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" styleClass="content-padding" spacing="20.0">

                <HBox spacing="20.0" alignment="CENTER_LEFT" styleClass="card">
                    <Label text="IC" styleClass="profile-btn"/>
                    <VBox spacing="6.0">
                        <Label text="Username"     styleClass="card-label"/>
                        <Label text="ion.costescu" styleClass="text-dark"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Edit Username" styleClass="btn-outline"/>
                </HBox>

                <VBox spacing="12.0" styleClass="card">
                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="2.0">
                            <Label text="Income History"                                    styleClass="section-title"/>
                            <Label text="Income entries used to calculate savings in reports" styleClass="section-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="+ Add Income" styleClass="btn-primary"/>
                    </HBox>

                    <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="inline-form">
                        <Label text="Amount (Lei):" styleClass="text-muted"/>
                        <TextField promptText="e.g. 4000.00" prefWidth="140.0" styleClass="input-field"/>
                        <Label text="Valid from:" styleClass="text-muted"/>
                        <TextField promptText="YYYY-MM-DD" prefWidth="140.0" styleClass="input-field"/>
                        <Button text="Save" styleClass="btn-success"/>
                    </HBox>

                    <TableView prefHeight="260.0" styleClass="table-card">
                        <columns>
                            <TableColumn text="Amount (Lei)" prefWidth="200.0"/>
                            <TableColumn text="Valid From"   prefWidth="200.0"/>
                            <TableColumn text="Valid Until"  prefWidth="200.0"/>
                        </columns>
                        <placeholder>
                            <Label text="No income entries yet." styleClass="text-muted"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </VBox>
        </VBox>
    </center>
</BorderPane>